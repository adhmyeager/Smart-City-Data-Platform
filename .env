# ============================================================
#  Smart City Data Platform — Environment Variables
#  1. Copy this file:   copy .env.example .env   (Windows)
#  2. Fill in values below
#  3. NEVER commit .env to git  (it's in .gitignore)
# ============================================================

# ── AWS S3  (Data Lake) ──────────────────────────────────────
# Create a free AWS account → IAM → Create user → Attach S3FullAccess
# Then create an S3 bucket named exactly: smart-city-datalake-<yourname>
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=smart-city-datalake-yourname

# ── Snowflake  (Data Warehouse) ──────────────────────────────
# Free 30-day trial at: https://signup.snowflake.com
# After signup → click your username (top right) → copy account identifier
# Format: abc12345.us-east-1  (no .snowflakecomputing.com)
SNOWFLAKE_ACCOUNT=your_account_here
SNOWFLAKE_USER=your_username_here
SNOWFLAKE_PASSWORD=your_password_here
SNOWFLAKE_DATABASE=SMART_CITY_DB
SNOWFLAKE_WAREHOUSE=SMART_CITY_WH
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=SYSADMIN

# ── OpenWeatherMap API ───────────────────────────────────────
# Free at: https://openweathermap.org/api  (1,000 calls/day free)
# Sign up → API keys tab → copy default key
OPENWEATHER_API_KEY=your_key_here

# ── TomTom Traffic API  (optional) ──────────────────────────
# Free at: https://developer.tomtom.com  (2,500 calls/day free)
# Register → My Apps → Create app → copy API key
TOMTOM_API_KEY=************************
# ── Kafka ────────────────────────────────────────────────────
# Do NOT change these — they match the docker-compose.yml settings
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TELEMETRY=vehicle-telemetry
KAFKA_TOPIC_WEATHER=weather-data
KAFKA_TOPIC_TRAFFIC=traffic-events
KAFKA_TOPIC_ROAD_EVENTS=road-events
KAFKA_TOPIC_ALERTS=alerts

# ── Simulation settings ──────────────────────────────────────
SIM_VEHICLE_COUNT=5
SIM_EMIT_INTERVAL_SECONDS=1
SIM_ROUTE=tahrir_to_new_capital

# ── Airflow ──────────────────────────────────────────────────
# Generate your Fernet key by running:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=****************

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=smartcity123
